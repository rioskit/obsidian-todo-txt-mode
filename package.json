{
	"name": "obsidian-todo-txt-mode",
	"version": "1.0.5",
	"description": "Support for todo.txt file format with syntax highlighting and task management",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:coverage": "jest --coverage",
		"lint": "eslint src --ext .ts",
		"lint:fix": "eslint src --ext .ts --fix",
		"check": "npm run lint && npx tsc -noEmit -skipLibCheck && npm test"
	},
	"keywords": [
		"todo.txt",
		"task"
	],
	"author": "Riosk It",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/rioskit/obsidian-todo-txt-mode"
	},
	"devDependencies": {
		"@types/jest": "^30.0.0",
		"@types/node": "^16.11.6",
		"@typescript-eslint/eslint-plugin": "5.29.0",
		"@typescript-eslint/parser": "5.29.0",
		"builtin-modules": "3.3.0",
		"esbuild": "0.17.3",
		"eslint": "^8.57.1",
		"jest": "^29.7.0",
		"jest-environment-jsdom": "^29.7.0",
		"obsidian": "latest",
		"ts-jest": "^29.4.0",
		"tslib": "2.4.0",
		"typescript": "4.7.4"
	}
}
